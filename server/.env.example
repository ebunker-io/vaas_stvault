export BACKEND_INTERNAL_SERVICE_TOKEN=''
# Comma-separated IP / CIDR allowlist for internal endpoints. Access requires either a whitelisted source IP OR a valid token.
# Example: "10.0.0.0/8,192.168.1.5". Leave empty to rely solely on the token.
export BACKEND_INTERNAL_SERVICE_IP_WHITELIST=''
# Upstream Ethereum mainnet JSON-RPC URL with provider key (e.g. Alchemy, Infura).
# Held server-side and never shipped to the browser; the dApp talks to /apis/rpc/eth-mainnet.
export BACKEND_RPC_MAINNET_UPSTREAM='https://eth-mainnet.g.alchemy.com/v2/REPLACE_WITH_KEY'
# Upstream Hoodi testnet JSON-RPC URL with provider key. Same pattern as mainnet;
# the dApp talks to /apis/rpc/hoodi instead of hitting the upstream directly.
export BACKEND_RPC_HOODI_UPSTREAM='https://eth-hoodi.g.alchemy.com/v2/REPLACE_WITH_KEY'